# ==========================================
# TaskFlow Backend Environment Variables
# Copy this file to '.env' and fill in values
# ==========================================

# Server Configuration
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# Database configuration
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/taskflow?retryWrites=true&w=majority

# Authentication
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRE=30d

# Redis Caching (Optional but recommended, falls back to memory safely if unavailable)
REDIS_URL=redis://localhost:6379

# File Upload / Storage (Cloudinary)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Payments (Razorpay)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Observability (Sentry)
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0